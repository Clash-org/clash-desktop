{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clash",
  "version": "2.0.0",
  "identifier": "Clash",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clash",
        "width": 1200,
        "height": 1000,
        "maximized": true,
        "label": "main",
        "url": "index.html",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["clash"]
      },
      "mobile": [
        {
          "scheme": ["clash"],
          "appLink": false
        }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERGMDdENUVEMkEzRDVEMwpSV1RUMWFQU1huM3dEVXM4REFvRjFPQmFaU3NSYVBBYVdZRVFGK2FzZ0pVL1F4VHUrTGZFY1Q1Wgo=",
      "endpoints": [
        "https://github.com/Clash-org/clash-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "linux": {
        "deb": {
          "depends": ["webkit2gtk"]
        },
        "appimage": {}
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "12",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": "./entitlements.plist",
      "hardenedRuntime": true
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "Clash is a professional application for organizing and holding sports tournaments. It allows you to create pools of participants, count points with a timer, create playoff grids, export results to Excel and synchronize data between devices via P2P.",
    "shortDescription": "Tournament management with P2P synchronization",
    "copyright": "© 2026 Clash",
    "publisher": "Artem Podloboshnikov"
  }
}
